package {
    default_applicable_licenses: ["packages_apps_HTMLViewer_license"],
}

license {
    name: "packages_apps_HTMLViewer_license",
    visibility: [":__subpackages__"],
    license_kinds: ["SPDX-license-identifier-Apache-2.0"],
    license_text: ["NOTICE"],
}

android_app {
    name: "HTMLViewer",
    srcs: ["**/*.java"],
    sdk_version: "current",
}
